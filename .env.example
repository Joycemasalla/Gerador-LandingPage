# =============================================================
# ARQUIVO DE EXEMPLO - Copie para .env e preencha com seus valores
# NÃO commite o arquivo .env com valores reais no GitHub!
# Configure as variáveis abaixo diretamente no painel do seu
# serviço de deploy (Vercel, Netlify, etc.)
# =============================================================

# Supabase
VITE_SUPABASE_PROJECT_ID="seu_project_id_aqui"
VITE_SUPABASE_PUBLISHABLE_KEY="seu_publishable_key_aqui"
VITE_SUPABASE_URL="https://seu_project_id.supabase.co"

# Google Gemini API
# Opção 1: Chave completa
VITE_GEMINI_API_KEY="sua_chave_gemini_aqui"
# Opção 2: Chave dividida em duas partes (opcional)
VITE_GEMINI_API_KEY_P1="primeira_parte_da_chave"
VITE_GEMINI_API_KEY_P2="segunda_parte_da_chave"

# Apify (para scraping do Instagram)
VITE_APIFY_API_TOKEN="seu_token_apify_aqui"
